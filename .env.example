# A generated secret for Payload
PAYLOAD_SECRET=

# ── Reservation system integrations (spec §6) ───────────────────────────────
# Set these as Wrangler secrets in production (`wrangler secret put NAME`) and in
# `.dev.vars` locally. NEVER commit real values.

# E-mail (Cloudflare Email Service via the SEND_EMAIL binding)
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=

# PayU (https://developers.payu.com)
PAYU_BASE_URL=
PAYU_CLIENT_ID=
PAYU_CLIENT_SECRET=
PAYU_POS_ID=
PAYU_SECOND_KEY=

# SMSAPI.pl (https://www.smsapi.pl/docs)
SMSAPI_TOKEN=
SMSAPI_SENDER=

# MailerLite (https://developers.mailerlite.com)
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Opinie Google (Places API New) — bez tych kluczy komponent opinii używa
# treści z CMS (fallback). Prod: `wrangler secret put GOOGLE_PLACES_API_KEY` itd.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
